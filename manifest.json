{
  "manifest_version": 3,
  "name": "Auto Admit for Google Meet",
  "version": "1.0.0",
  "description": "Automatically admits people to your Google Meet calls",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
